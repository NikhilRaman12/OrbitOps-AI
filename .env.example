# OrbitOps AI - Environment Configuration Template

# ==============================================================================
# GitLab Orbit Context Integration (Production)
# ==============================================================================
# To enable active GitLab repository context fetching, configure these.
# If omitted, OrbitOps AI runs in offline-fallback/demo mode automatically.

# GitLab Personal Access Token with read_repository, read_api scope
GITLAB_PERSONAL_ACCESS_TOKEN=your-gitlab-token-here

# Target GitLab Project ID (numeric or url-encoded path)
GITLAB_PROJECT_ID=12345678

# GitLab API Base URL (defaults to gitlab.com if empty)
GITLAB_API_URL=https://gitlab.com/api/v4


# ==============================================================================
# Frontend Environment Configuration
# ==============================================================================
# Base URL targeting the FastAPI backend server
VITE_API_BASE_URL=http://localhost:8000
